# swiss-courts-mcp — Beispiel-Konfiguration
# ==========================================
# Kopiere diese Datei nach `.env` und passe die Werte an.
# Für den lokalen stdio-Betrieb (Claude Desktop) ist KEINE Konfiguration nötig.
# Die folgenden Variablen betreffen ausschliesslich den HTTP-/Cloud-Modus.

# --- Transport / Netzwerk (HTTP-Modus) ---
# Bind-Host. Default ist 127.0.0.1 (nur lokal erreichbar).
# Im Container/Cloud bewusst auf 0.0.0.0 setzen — und nur dann.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Erlaubt explizit das Binden an 0.0.0.0 ohne Warnung (nur in Containern setzen).
# MCP_ALLOW_PUBLIC_BIND=1

# Stateless HTTP (true = horizontal skalierbar ohne Sticky-Sessions).
MCP_STATELESS_HTTP=true

# --- Authentifizierung (HTTP-Modus, SEC-009) ---
# Aktiviert Bearer-Token-Auth für den HTTP-Transport.
MCP_AUTH_ENABLED=false

# Symmetrisches Secret für HS256-JWTs (Entwicklung / einfache Deployments).
# MCP_AUTH_SECRET=change-me-to-a-long-random-secret

# Alternativ: JWKS-URL des IdP für RS256-Validierung (Produktion).
# MCP_OAUTH_JWKS_URL=https://idp.example.ch/.well-known/jwks.json

# Erwarteter Issuer und Audience/Resource für die Token-Validierung.
# MCP_OAUTH_ISSUER=https://idp.example.ch/
# MCP_OAUTH_AUDIENCE=swiss-courts-mcp

# Komma-separierte Liste erforderlicher Scopes.
# MCP_REQUIRED_SCOPES=courts:read

# --- CORS (HTTP-Modus, SDK-004) ---
# Komma-separierte erlaubte Origins. In Produktion keine Wildcard.
# MCP_CORS_ORIGINS=https://app.example.ch
